APP_ENV=local
APP_PORT=8080
FRONTEND_URL=http://localhost:3000

DATABASE_DSN=ednic:<your-local-password>@tcp(127.0.0.1:3306)/ednic_local?parseTime=true
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=25
DATABASE_CONN_MAX_LIFETIME_MINUTES=5

JWT_SECRET=<change-me>
JWT_ACCESS_TOKEN_TTL_MINUTES=60

SUPER_ADMIN_NAME=<your-name>
SUPER_ADMIN_USERNAME=<your-admin-username>
SUPER_ADMIN_EMAIL=<your-admin-email>
SUPER_ADMIN_PASSWORD=<your-admin-password>

MYSQL_ROOT_PASSWORD=<your-local-password>
MYSQL_DATABASE=ednic_local
MYSQL_USER=ednic
MYSQL_PASSWORD=<your-local-password>

MINIO_ROOT_USER=ednic_minio
MINIO_ROOT_PASSWORD=<your-minio-password>
MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE=http://localhost:9001
MINIO_PUBLIC_BUCKET=ednic-public
MINIO_PRIVATE_BUCKET=ednic-private
